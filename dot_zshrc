# Init 
eval "$(starship init zsh)"
eval "$(atuin init zsh)"

# Options
setopt AUTO_CD
setopt no_prompt_cr
setopt no_prompt_sp

# Editor
export EDITOR=nvim
export VISUAL=nvim

# PATH
export PATH="$HOME/.local/bin:$PATH"

# Aliases 
alias ls="lsd -l --icon=always"
alias lst="lsd -l --tree --icon=always"
alias lsa="lsd -a --long --icon=always"
alias ff="fastfetch"
alias vi="nvim"
alias btop='btop --force-utf'
alias lg="lazygit"

# Git
alias gs='git status --column'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gp='git pull'
alias gP='git push'
alias gd='git diff'
alias gds='git diff --staged'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit'
alias gcm='git commit -m'
alias gl="git log --decorate=full --color=always"
alias gll="git log --oneline"

# Dev Shortcuts
alias uvr="uv run"
alias lg="lazygit"          
alias dk="docker"
alias dkc="docker compose"

# Quick activate for uv/venv
alias va="source .venv/bin/activate"
alias vd="deactivate"

# Enable Vi mode
bindkey -v

# Completion
autoload -Uz compinit
compinit
zstyle ':completion:*' matcher-list \
  'm:{a-z}={A-Z}' \
  'r:|[._-]=* r:|=*'
zstyle ':completion:*' menu select

# Plugins 
source ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source ~/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
